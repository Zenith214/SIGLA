generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model SurveyTarget {
  target_id   Int       @id @default(autoincrement())
  barangay_id Int
  target      Int
  achieved    Int?
  percentage  Int?
  created_at  DateTime  @default(now())
  updated_at  DateTime?
  barangay    barangay  @relation(fields: [barangay_id], references: [barangay_id], onDelete: Cascade)

  @@index([barangay_id], map: "survey_target_barangay_id_fkey")
  @@map("survey_target")
}

model assignment {
  assignment_id Int       @id @default(autoincrement())
  barangay_id   Int
  user_id       Int
  status        String    @default("Pending")
  progress      Int?
  created_at    DateTime  @default(now())
  updated_at    DateTime?
  barangay      barangay  @relation(fields: [barangay_id], references: [barangay_id], onDelete: Cascade, map: "Assignment_barangay_id_fkey")
  user          user      @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "Assignment_user_id_fkey")

  @@index([barangay_id], map: "Assignment_barangay_id_fkey")
  @@index([user_id], map: "Assignment_user_id_fkey")
}

model backup {
  backup_id Int      @id @default(autoincrement())
  date      DateTime
  time      DateTime
  size      String?
  status    String   @default("Success")
}

model barangay {
  barangay_id   Int            @id @default(autoincrement())
  barangay_name String         @unique(map: "Barangay_barangay_name_key")
  seal          String         @default("no")
  description   String?
  is_active     Boolean        @default(true)
  created_at    DateTime       @default(now())
  updated_at    DateTime?
  households    Int?
  population    Int?
  captain       String?
  currentStatus String?
  history       String?        @db.LongText
  is_awardee    Boolean        @default(false)
  area          Float?
  assignment    assignment[]
  survey        survey[]
  surveyTargets SurveyTarget[]
}

model survey {
  survey_id     Int       @id @default(autoincrement())
  barangay_id   Int
  status        String    @default("draft")
  analyzed_data String?   @db.LongText
  raw_data      String?   @db.LongText
  created_at    DateTime  @default(now())
  updated_at    DateTime?
  barangay      barangay  @relation(fields: [barangay_id], references: [barangay_id], onDelete: Cascade, map: "Survey_barangay_id_fkey")

  @@index([barangay_id], map: "Survey_barangay_id_fkey")
}

model surveycycle {
  cycle_id   Int       @id @default(autoincrement())
  year       String
  status     String    @default("Active")
  start_date DateTime
  end_date   DateTime
  responses  Int?
  created_at DateTime  @default(now())
  updated_at DateTime?
}

model user {
  id           Int          @id @default(autoincrement())
  email        String       @unique(map: "User_email_key")
  password     String
  createdAt    DateTime     @default(now())
  firstName    String
  jobTitle     String?
  lastName     String
  organization String?
  phone        String?
  role         String?
  status       String?
  lastLogin    DateTime?
  assignment   assignment[]
}
