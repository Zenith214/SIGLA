// This is your Prisma schema file for SIGLA Survey System
// Migrated from MySQL to PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// USER MANAGEMENT
// ============================================================================

model User {
  id                  Int       @id @default(autoincrement())
  email               String    @unique @db.VarChar(191)
  password            String    @db.VarChar(191)
  createdAt           DateTime  @default(now()) @map("createdAt")
  firstName           String    @db.VarChar(191)
  jobTitle            String?   @db.VarChar(191)
  lastName            String    @db.VarChar(191)
  organization        String?   @db.VarChar(191)
  phone               String?   @db.VarChar(191)
  role                String?   @default("officer") @db.VarChar(32)
  status              String?   @default("Active") @db.VarChar(16)
  lastLogin           DateTime?
  barangayDesignation Int?

  // Relations
  assignments              Assignment[]
  survey_responses         SurveyResponse[]
  created_awards           CycleAward[]
  assigned_spots           Spot[]
  cpap_comments            CPAPComment[]
  cpap_notifications       CPAPNotification[]       @relation("UserNotifications")
  created_notifications    CPAPNotification[]       @relation("CreatedNotifications")
  designated_barangay      Barangay?                @relation("OfficerDesignation", fields: [barangayDesignation], references: [barangay_id], onDelete: SetNull)

  @@index([barangayDesignation])
  @@map("user")
}

// ============================================================================
// BARANGAY MANAGEMENT
// ============================================================================

model Barangay {
  barangay_id   Int          @id @default(autoincrement())
  barangay_name String       @unique @db.VarChar(191)
  seal          BarangaySeal @default(no)
  description   String?      @db.Text
  is_active     Boolean      @default(true)
  created_at    DateTime     @default(now())
  updated_at    DateTime?    @updatedAt
  households    Int?         @default(0)
  population    Int?         @default(0)
  captain       String?      @db.VarChar(191)
  currentStatus String?      @db.VarChar(32)
  history       Json?

  // Relations
  assignments         Assignment[]
  surveys             Survey[]
  survey_responses    SurveyResponse[]
  survey_targets      SurveyTarget[]
  year_data           BarangayYearData[]
  cycle_awards        CycleAward[]
  spots               Spot[]
  cpaps               CPAP[]
  designated_officers User[]             @relation("OfficerDesignation")

  @@map("barangay")
}

// ============================================================================
// ASSIGNMENT MANAGEMENT
// ============================================================================

model Assignment {
  assignment_id   Int              @id @default(autoincrement())
  barangay_id     Int
  user_id         Int
  survey_cycle_id Int?
  status          AssignmentStatus @default(Pending)
  progress        Int?             @default(0)
  created_at      DateTime         @default(now())
  updated_at      DateTime?        @updatedAt

  // Relations
  barangay     Barangay     @relation(fields: [barangay_id], references: [barangay_id], onDelete: Cascade)
  user         User         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  survey_cycle SurveyCycle? @relation(fields: [survey_cycle_id], references: [cycle_id], onDelete: SetNull)

  @@index([barangay_id])
  @@index([user_id])
  @@index([survey_cycle_id])
  @@map("assignment")
}

// ============================================================================
// BACKUP MANAGEMENT
// ============================================================================

model Backup {
  backup_id Int          @id @default(autoincrement())
  date      DateTime     @db.Date
  time      DateTime     @db.Time
  size      String?      @db.VarChar(20)
  status    BackupStatus @default(Success)

  @@map("backup")
}

model DataExportLog {
  id           Int      @id @default(autoincrement())
  user_id      Int
  export_type  String   @db.VarChar(50)
  anonymized   Boolean  @default(true)
  record_count Int      @default(0)
  exported_at  DateTime @default(now())
  ip_address   String?  @db.VarChar(45)
  user_agent   String?  @db.Text

  @@index([user_id])
  @@index([exported_at])
  @@index([export_type])
  @@index([anonymized])
  @@map("data_export_log")
}

// ============================================================================
// SURVEY MANAGEMENT
// ============================================================================

model Survey {
  survey_id     Int          @id @default(autoincrement())
  barangay_id   Int
  status        SurveyStatus @default(draft)
  analyzed_data Json?
  raw_data      Json?
  created_at    DateTime     @default(now())
  updated_at    DateTime?    @updatedAt

  // Relations
  barangay    Barangay    @relation(fields: [barangay_id], references: [barangay_id], onDelete: Cascade)
  survey_logs SurveyLog[]

  @@index([barangay_id])
  @@map("survey")
}

model SurveyLog {
  log_id     Int      @id @default(autoincrement())
  survey_id  Int
  action     String   @db.VarChar(191)
  details    String?  @db.Text
  created_at DateTime @default(now())

  // Relations
  survey Survey @relation(fields: [survey_id], references: [survey_id], onDelete: Cascade)

  @@index([survey_id])
  @@map("survey_log")
}

// ============================================================================
// SURVEY RESPONSE SYSTEM
// ============================================================================

model SurveyResponse {
  response_id           Int                   @id @default(autoincrement())
  survey_number         String                @unique @db.VarChar(50)
  barangay_id           Int
  interviewer_id        Int
  survey_cycle_id       Int?
  questionnaire_id      String?               @unique @db.VarChar(50)
  spot_id               Int?
  visit_count           Int?                  @default(1)
  respondent_name       String?               @db.VarChar(191)
  respondent_age        Int?
  respondent_gender     SurveyResponseGender?
  location_lat          Decimal               @db.Decimal(10, 8)
  location_lng          Decimal               @db.Decimal(11, 8)
  location_address      String?               @db.Text
  location_accuracy     Decimal?              @db.Decimal(8, 2)
  location_timestamp    DateTime?
  location_barangay     String?               @db.VarChar(191)
  location_municipality String?               @db.VarChar(191)
  location_province     String?               @db.VarChar(191)
  status                SurveyResponseStatus  @default(draft)
  progress              Int?                  @default(0)
  started_at            DateTime              @default(now())
  completed_at          DateTime?
  submitted_at          DateTime?
  created_at            DateTime              @default(now())
  updated_at            DateTime?             @updatedAt
  unawareness_reasons   Json?                 @default("{}")
  non_availment_reasons Json?                 @default("{}")

  // Relations
  barangay      Barangay           @relation(fields: [barangay_id], references: [barangay_id], onDelete: Cascade)
  interviewer   User               @relation(fields: [interviewer_id], references: [id], onDelete: Cascade)
  survey_cycle  SurveyCycle?       @relation(fields: [survey_cycle_id], references: [cycle_id], onDelete: SetNull)
  questionnaire Questionnaire?     @relation(fields: [questionnaire_id], references: [questionnaire_id], onDelete: SetNull)
  spot          Spot?              @relation(fields: [spot_id], references: [spot_id], onDelete: SetNull)
  sections      SurveySection[]
  answers       SurveyAnswer[]
  attachments   SurveyAttachment[]
  metadata      SurveyMetadata[]
  validations   SurveyValidation[]

  @@index([status])
  @@index([interviewer_id])
  @@index([barangay_id])
  @@index([survey_cycle_id])
  @@index([questionnaire_id])
  @@index([spot_id])
  @@index([created_at])
  @@index([completed_at])
  @@map("survey_response")
}

model SurveySection {
  section_id   Int                 @id @default(autoincrement())
  response_id  Int
  section_name String              @db.VarChar(100)
  section_key  String              @db.VarChar(50)
  status       SurveySectionStatus @default(pending)
  data         Json?
  started_at   DateTime?
  completed_at DateTime?
  created_at   DateTime            @default(now())
  updated_at   DateTime?           @updatedAt

  // Relations
  response  SurveyResponse   @relation(fields: [response_id], references: [response_id], onDelete: Cascade)
  questions SurveyQuestion[]

  @@unique([response_id, section_key])
  @@index([status])
  @@index([section_key])
  @@map("survey_section")
}

model SurveyQuestion {
  question_id   Int                @id @default(autoincrement())
  section_id    Int
  question_key  String             @db.VarChar(100)
  question_text String             @db.Text
  question_type SurveyQuestionType
  options       Json?
  required      Boolean            @default(false)
  order_index   Int                @default(0)
  depends_on    String?            @db.VarChar(100)
  depends_value String?            @db.VarChar(191)
  created_at    DateTime           @default(now())

  // Relations
  section SurveySection  @relation(fields: [section_id], references: [section_id], onDelete: Cascade)
  answers SurveyAnswer[]

  @@index([question_key])
  @@index([section_id])
  @@map("survey_question")
}

model SurveyAnswer {
  answer_id      Int       @id @default(autoincrement())
  question_id    Int
  response_id    Int
  answer_value   String?   @db.Text
  answer_options Json?
  answer_text    String?   @db.Text
  answer_number  Decimal?  @db.Decimal(10, 2)
  answer_rating  Int?
  created_at     DateTime  @default(now())
  updated_at     DateTime? @updatedAt

  // Relations
  question SurveyQuestion @relation(fields: [question_id], references: [question_id], onDelete: Cascade)
  response SurveyResponse @relation(fields: [response_id], references: [response_id], onDelete: Cascade)

  @@unique([question_id, response_id])
  @@index([response_id])
  @@map("survey_answer")
}

model SurveyAttachment {
  attachment_id Int      @id @default(autoincrement())
  response_id   Int
  file_name     String   @db.VarChar(255)
  file_path     String   @db.VarChar(500)
  file_type     String?  @db.VarChar(100)
  file_size     Int?
  description   String?  @db.Text
  uploaded_at   DateTime @default(now())

  // Relations
  response SurveyResponse @relation(fields: [response_id], references: [response_id], onDelete: Cascade)

  @@index([response_id])
  @@map("survey_attachment")
}

model SurveyMetadata {
  metadata_id Int      @id @default(autoincrement())
  response_id Int
  key_name    String   @db.VarChar(100)
  key_value   String?  @db.Text
  created_at  DateTime @default(now())

  // Relations
  response SurveyResponse @relation(fields: [response_id], references: [response_id], onDelete: Cascade)

  @@unique([response_id, key_name])
  @@index([response_id])
  @@map("survey_metadata")
}

model SurveyValidation {
  validation_id      Int                    @id @default(autoincrement())
  response_id        Int
  validation_type    SurveyValidationType
  validation_status  SurveyValidationStatus
  validation_message String?                @db.Text
  validation_data    Json?
  created_at         DateTime               @default(now())

  // Relations
  response SurveyResponse @relation(fields: [response_id], references: [response_id], onDelete: Cascade)

  @@index([validation_type])
  @@index([validation_status])
  @@index([response_id])
  @@map("survey_validation")
}

// ============================================================================
// SURVEY CYCLES & TARGETS
// ============================================================================

model SurveyCycle {
  cycle_id   Int       @id @default(autoincrement())
  name       String    @db.VarChar(191)
  year       Int
  is_active  Boolean   @default(false)
  start_date DateTime? @db.Date
  end_date   DateTime? @db.Date
  created_at DateTime  @default(now())
  updated_at DateTime? @updatedAt

  // Relations
  survey_responses SurveyResponse[]
  survey_targets   SurveyTarget[]
  assignments      Assignment[]
  cycle_awards     CycleAward[]
  spots            Spot[]
  questionnaires   Questionnaire[]
  cpaps            CPAP[]

  @@index([is_active])
  @@map("survey_cycle")
}

model SurveyTarget {
  target_id       Int       @id @default(autoincrement())
  barangay_id     Int
  survey_cycle_id Int?
  target          Int
  achieved        Int?      @default(0)
  percentage      Int?      @default(0)
  created_at      DateTime  @default(now())
  updated_at      DateTime? @updatedAt

  // Relations
  barangay     Barangay     @relation(fields: [barangay_id], references: [barangay_id], onDelete: Cascade)
  survey_cycle SurveyCycle? @relation(fields: [survey_cycle_id], references: [cycle_id], onDelete: SetNull)

  @@index([barangay_id])
  @@index([survey_cycle_id])
  @@map("survey_target")
}

// ============================================================================
// CYCLE-AWARE AWARD MANAGEMENT
// ============================================================================

model CycleAward {
  id           Int       @id @default(autoincrement())
  barangay_id  Int
  cycle_id     Int
  is_awardee   Boolean   @default(false)
  awarded_date DateTime?
  notes        String?   @db.Text
  created_at   DateTime  @default(now())
  updated_at   DateTime? @updatedAt
  created_by   Int?

  // Relations
  barangay     Barangay    @relation(fields: [barangay_id], references: [barangay_id], onDelete: Cascade)
  survey_cycle SurveyCycle @relation(fields: [cycle_id], references: [cycle_id], onDelete: Cascade)
  creator      User?       @relation(fields: [created_by], references: [id], onDelete: SetNull)

  @@unique([barangay_id, cycle_id])
  @@index([cycle_id])
  @@index([barangay_id])
  @@index([is_awardee])
  @@index([created_at])
  @@map("cycle_awards")
}

// ============================================================================
// YEAR-SPECIFIC BARANGAY DATA
// ============================================================================

model BarangayYearData {
  id                Int          @id @default(autoincrement())
  barangay_id       Int
  year              String       @db.VarChar(10)
  seal_status       BarangaySeal @default(no)
  survey_status     String?      @db.VarChar(50)
  survey_count      Int?         @default(0)
  completion_rate   Decimal?     @db.Decimal(5, 2)
  target_achieved   Int?         @default(0)
  target_percentage Int?         @default(0)
  notes             String?      @db.Text
  created_at        DateTime     @default(now())
  updated_at        DateTime?    @updatedAt

  // Relations
  barangay Barangay @relation(fields: [barangay_id], references: [barangay_id], onDelete: Cascade)

  @@unique([barangay_id, year])
  @@index([year])
  @@index([barangay_id])
  @@index([seal_status])
  @@map("barangay_year_data")
}

// ============================================================================
// CSIS WORKFLOW - SPOT MANAGEMENT
// ============================================================================

model Spot {
  spot_id        Int        @id @default(autoincrement())
  cycle_id       Int
  barangay_id    Int
  spot_name      String     @db.VarChar(100)
  starting_point Json // { lat: number, lng: number }
  random_start   Int // 1-999
  assigned_fi_id Int?
  status         SpotStatus @default(Pending)
  created_at     DateTime   @default(now())
  updated_at     DateTime?  @updatedAt

  // Relations
  cycle            SurveyCycle      @relation(fields: [cycle_id], references: [cycle_id], onDelete: Cascade)
  barangay         Barangay         @relation(fields: [barangay_id], references: [barangay_id], onDelete: Cascade)
  assigned_fi      User?            @relation(fields: [assigned_fi_id], references: [id], onDelete: SetNull)
  questionnaires   Questionnaire[]
  survey_responses SurveyResponse[]

  @@index([cycle_id])
  @@index([barangay_id])
  @@index([assigned_fi_id])
  @@index([status])
  @@map("spots")
}

model Questionnaire {
  questionnaire_id String              @id @db.VarChar(50) // e.g., "2024-001-001"
  spot_id          Int
  cycle_id         Int
  sequence_number  Int // 1-5 within spot
  status           QuestionnaireStatus @default(Pending)
  visit_count      Int                 @default(0)
  created_at       DateTime            @default(now())
  updated_at       DateTime?           @updatedAt

  // Relations
  spot            Spot            @relation(fields: [spot_id], references: [spot_id], onDelete: Cascade)
  cycle           SurveyCycle     @relation(fields: [cycle_id], references: [cycle_id], onDelete: Cascade)
  visits          Visit[]
  survey_response SurveyResponse?

  @@index([spot_id])
  @@index([cycle_id])
  @@index([status])
  @@map("questionnaires")
}

model Visit {
  visit_id         Int          @id @default(autoincrement())
  questionnaire_id String
  visit_number     Int
  visit_timestamp  DateTime     @default(now())
  outcome          VisitOutcome
  notes            String?      @db.Text
  location_lat     Decimal?     @db.Decimal(10, 8)
  location_lng     Decimal?     @db.Decimal(11, 8)
  created_at       DateTime     @default(now())

  // Relations
  questionnaire Questionnaire @relation(fields: [questionnaire_id], references: [questionnaire_id], onDelete: Cascade)

  @@index([questionnaire_id])
  @@index([visit_timestamp])
  @@map("visits")
}

// ============================================================================
// ENUMS
// ============================================================================

enum BarangaySeal {
  yes
  no
}

enum AssignmentStatus {
  Active
  Pending
  Completed
}

enum BackupStatus {
  Success
  Failed
}

enum SurveyStatus {
  draft
  ongoing
  completed
  archived
}

enum SurveyCycleStatus {
  Active
  Completed
  Archived
}

enum SurveyQuestionType {
  radio
  checkbox
  text
  textarea
  number
  rating
}

enum SurveyResponseGender {
  Male
  Female
  Other
}

enum SurveyResponseStatus {
  draft
  in_progress
  completed
  submitted
}

enum SurveySectionStatus {
  pending
  in_progress
  completed
}

enum SurveyValidationType {
  location
  completeness
  consistency
  quality
}

enum SurveyValidationStatus {
  passed
  failed
  warning
}

enum SpotStatus {
  Pending
  In_Progress
  Completed
}

enum QuestionnaireStatus {
  Pending
  In_Progress
  Completed
  Flagged_For_Substitution
}

enum VisitOutcome {
  Callback_Needed
  Interview_Started
  Interview_Completed
  Refused
  Household_Moved
}

// ============================================================================
// CPAP (CITIZEN PRIORITY ACTION PLAN) MODULE
// ============================================================================

model CPAP {
  id             Int                @id @default(autoincrement())
  barangay_id    Int
  cycle_id       Int
  status         CPAPStatus         @default(Draft)
  created_at     DateTime           @default(now())
  updated_at     DateTime           @updatedAt
  submitted_at   DateTime?
  approved_at    DateTime?
  admin_comments String?            @db.Text

  // Relations
  barangay      Barangay           @relation(fields: [barangay_id], references: [barangay_id], onDelete: Cascade)
  cycle         SurveyCycle        @relation(fields: [cycle_id], references: [cycle_id], onDelete: Cascade)
  items         CPAPItem[]
  comments      CPAPComment[]
  notifications CPAPNotification[]

  @@unique([barangay_id, cycle_id])
  @@index([status])
  @@index([barangay_id])
  @@index([cycle_id])
  @@map("cpaps")
}

model CPAPItem {
  id                       Int       @id @default(autoincrement())
  cpap_id                  Int
  priority_area            String    @db.VarChar(255)
  target_output            String    @db.Text
  success_indicator        String    @db.Text
  responsible_person       String    @db.VarChar(255)
  timeline_start           DateTime  @db.Date
  timeline_end             DateTime  @db.Date
  actual_output            String?   @db.Text
  accomplishment_status    String?   @db.VarChar(50)
  remarks                  String?   @db.Text
  // New spreadsheet columns
  observation              String?   @db.Text
  plan_of_action           String?   @db.Text
  activity                 String?   @db.Text
  financial_requirements   String?   @db.VarChar(255)
  committed_to_be_committed String?  @db.Text
  actual_date              String?   @db.Text
  progress                 String?   @db.VarChar(50) // Ongoing, Delayed, Completed
  created_at               DateTime  @default(now())
  updated_at               DateTime  @updatedAt

  // Relations
  cpap CPAP @relation(fields: [cpap_id], references: [id], onDelete: Cascade)

  @@index([cpap_id])
  @@map("cpap_items")
}

model CPAPComment {
  id           Int      @id @default(autoincrement())
  cpap_id      Int
  user_id      Int
  comment_text String   @db.Text
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  // Relations
  cpap CPAP @relation(fields: [cpap_id], references: [id], onDelete: Cascade)
  user User  @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([cpap_id])
  @@index([user_id])
  @@index([created_at])
  @@map("cpap_comments")
}

model CPAPNotification {
  id                Int      @id @default(autoincrement())
  user_id           Int
  cpap_id           Int
  notification_type String   @db.VarChar(50)
  message           String   @db.Text
  is_read           Boolean  @default(false)
  created_at        DateTime @default(now())
  created_by        Int?

  // Relations
  user       User  @relation("UserNotifications", fields: [user_id], references: [id], onDelete: Cascade)
  cpap       CPAP  @relation(fields: [cpap_id], references: [id], onDelete: Cascade)
  creator    User? @relation("CreatedNotifications", fields: [created_by], references: [id], onDelete: SetNull)

  @@index([user_id])
  @@index([cpap_id])
  @@index([is_read])
  @@index([created_at])
  @@map("cpap_notifications")
}

enum CPAPStatus {
  Draft
  Submitted
  Approved
  Revision_Requested
}
