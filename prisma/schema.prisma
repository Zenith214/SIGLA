generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                     Int                      @id @default(autoincrement())
  email                  String                   @unique
  password               String
  createdAt              DateTime                 @default(now()) @map("createdAt")
  firstName              String
  jobTitle               String?
  lastName               String
  organization           String?
  phone                  String?
  lastLogin              DateTime?
  role                   String?                  @default("officer")
  status                 String?                  @default("Active")
  profilePicture         String?
  barangayDesignation    Int?
  firstLogin             Boolean?                 @default(true)
  assignments            Assignment[]
  cpap_comments          CPAPComment[]
  created_notifications  CPAPNotification[]       @relation("CreatedNotifications")
  cpap_notifications     CPAPNotification[]       @relation("UserNotifications")
  created_awards         CycleAward[]
  fieldwork_attempts     fieldwork_attempts[]
  fieldwork_exceptions   fieldwork_exceptions[]
  questionnaires         Questionnaire[]
  assigned_spots         Spot[]
  supervisor_assignments supervisor_assignments[]
  survey_responses       SurveyResponse[]
  designated_barangay    Barangay?                @relation("OfficerDesignation", fields: [barangayDesignation], references: [barangay_id], onUpdate: NoAction)

  @@index([lastName, firstName])
  @@index([role])
  @@index([status])
  @@map("user")
}

model Barangay {
  barangay_id                Int                          @id @default(autoincrement())
  barangay_name              String                       @unique
  seal                       barangay_seal                @default(no)
  description                String?
  is_active                  Boolean                      @default(true)
  created_at                 DateTime                     @default(now())
  updated_at                 DateTime?                    @updatedAt
  households                 Int?                         @default(0)
  population                 Int?                         @default(0)
  area                       Decimal?
  captain                    String?
  currentStatus              String?
  history                    String?
  seal_expiration_date       DateTime?
  logo_url                   String?
  action_grid_classification action_grid_classification[]
  ai_insight                 ai_insight[]
  ai_recommendation          ai_recommendation[]
  assignments                Assignment[]
  barangay_history           barangay_history[]
  cpaps                      CPAP[]
  cycle_awards               CycleAward[]
  fieldwork_exceptions       fieldwork_exceptions[]
  ml_prediction              ml_prediction[]
  questionnaire_counter      questionnaire_counter[]
  spots                      Spot[]
  supervisor_assignments     supervisor_assignments[]
  surveys                    Survey[]
  survey_responses           SurveyResponse[]
  survey_targets             SurveyTarget[]
  designated_officers        User[]                       @relation("OfficerDesignation")

  @@index([is_active])
  @@index([seal])
  @@map("barangay")
}

model Assignment {
  assignment_id   Int               @id @default(autoincrement())
  barangay_id     Int
  user_id         Int
  status          assignment_status @default(Pending)
  progress        Int?              @default(0)
  created_at      DateTime          @default(now())
  updated_at      DateTime?         @updatedAt
  survey_cycle_id Int?
  barangay        Barangay          @relation(fields: [barangay_id], references: [barangay_id])
  user            User              @relation(fields: [user_id], references: [id])
  survey_cycle    SurveyCycle?      @relation(fields: [survey_cycle_id], references: [cycle_id], onUpdate: NoAction, map: "fk_assignment_cycle")

  @@index([barangay_id])
  @@index([user_id])
  @@index([status])
  @@index([survey_cycle_id], map: "idx_assignment_cycle_id")
  @@map("assignment")
}

model Backup {
  backup_id Int           @id @default(autoincrement())
  date      DateTime
  time      DateTime
  size      String?
  status    backup_status @default(Success)

  @@map("backup")
}

model Survey {
  survey_id     Int           @id @default(autoincrement())
  barangay_id   Int
  status        survey_status @default(draft)
  analyzed_data String?
  raw_data      String?
  created_at    DateTime      @default(now())
  updated_at    DateTime?     @updatedAt
  barangay      Barangay      @relation(fields: [barangay_id], references: [barangay_id])
  survey_logs   SurveyLog[]

  @@index([barangay_id])
  @@index([status])
  @@map("survey")
}

model SurveyLog {
  log_id     Int      @id @default(autoincrement())
  survey_id  Int
  action     String   @db.VarChar(100)
  details    String?
  created_at DateTime @default(now())
  survey     Survey   @relation(fields: [survey_id], references: [survey_id])

  @@index([survey_id])
  @@index([created_at])
  @@map("survey_log")
}

model SurveyResponse {
  response_id                       Int                                @id @default(autoincrement())
  survey_number                     String                             @unique
  barangay_id                       Int
  interviewer_id                    Int
  respondent_name                   String?                            @db.VarChar(255)
  respondent_age                    Int?
  respondent_gender                 survey_response_respondent_gender?
  location_lat                      Decimal                            @db.Decimal(10, 6)
  location_lng                      Decimal                            @db.Decimal(10, 6)
  location_address                  String?
  location_accuracy                 Decimal?                           @db.Decimal(10, 2)
  location_timestamp                DateTime?
  location_barangay                 String?                            @db.VarChar(100)
  location_municipality             String?                            @db.VarChar(100)
  location_province                 String?                            @db.VarChar(100)
  status                            survey_response_status             @default(draft)
  progress                          Int?                               @default(0)
  started_at                        DateTime                           @default(now())
  completed_at                      DateTime?
  submitted_at                      DateTime?
  created_at                        DateTime                           @default(now())
  updated_at                        DateTime?                          @updatedAt
  respondent_educational_attainment String?                            @db.VarChar(191)
  respondent_household_income       String?                            @db.VarChar(191)
  survey_cycle_id                   Int?
  respondent_purok                  String?                            @db.VarChar(50)
  questionnaire_id                  String?                            @unique @db.VarChar(50)
  spot_id                           Int?
  visit_count                       Int?                               @default(1)
  verification_location             Json?
  gps_verification_status           String?                            @default("pending") @db.VarChar(20)
  gps_distance_meters               Decimal?                           @db.Decimal(10, 2)
  biological_sex                    String?                            @db.VarChar(50)
  gender_identity                   String?                            @db.VarChar(100)
  unawareness_reasons               Json?                              @default("{}")
  non_availment_reasons             Json?                              @default("{}")
  answers                           SurveyAnswer[]
  attachments                       SurveyAttachment[]
  metadata                          SurveyMetadata[]
  survey_cycle                      SurveyCycle?                       @relation(fields: [survey_cycle_id], references: [cycle_id], onUpdate: NoAction, map: "fk_survey_response_cycle")
  barangay                          Barangay                           @relation(fields: [barangay_id], references: [barangay_id])
  interviewer                       User                               @relation(fields: [interviewer_id], references: [id])
  questionnaire                     Questionnaire?                     @relation(fields: [questionnaire_id], references: [questionnaire_id])
  spot                              Spot?                              @relation(fields: [spot_id], references: [spot_id])
  sections                          SurveySection[]
  validations                       SurveyValidation[]

  @@index([status])
  @@index([interviewer_id])
  @@index([barangay_id])
  @@index([questionnaire_id])
  @@index([spot_id])
  @@index([created_at])
  @@index([respondent_educational_attainment], map: "idx_respondent_education")
  @@index([respondent_household_income], map: "idx_respondent_income")
  @@index([biological_sex], map: "idx_survey_response_biological_sex")
  @@index([survey_cycle_id], map: "idx_survey_response_cycle_id")
  @@index([gender_identity], map: "idx_survey_response_gender_identity")
  @@index([gps_verification_status], map: "idx_survey_response_gps_status")
  @@index([non_availment_reasons], map: "idx_survey_response_non_availment_reasons", type: Gin)
  @@index([unawareness_reasons], map: "idx_survey_response_unawareness_reasons", type: Gin)
  @@map("survey_response")
}

model SurveySection {
  section_id   Int                   @id @default(autoincrement())
  response_id  Int
  section_name String                @db.VarChar(100)
  section_key  String                @db.VarChar(50)
  status       survey_section_status @default(pending)
  data         Json?
  started_at   DateTime?
  completed_at DateTime?
  created_at   DateTime              @default(now())
  updated_at   DateTime?             @updatedAt
  questions    SurveyQuestion[]
  response     SurveyResponse        @relation(fields: [response_id], references: [response_id])

  @@unique([response_id, section_key])
  @@unique([response_id, section_key], map: "unique_response_section_key")
  @@index([status])
  @@index([data(ops: JsonbPathOps)], map: "idx_survey_section_data_nfa_binary", type: Gin)
  @@index([section_key], map: "idx_survey_section_key")
  @@index([response_id], map: "idx_survey_section_response_id")
  @@index([response_id, section_key], map: "idx_survey_section_response_section")
  @@index([section_key], map: "idx_survey_section_section_key")
  @@index([status], map: "idx_survey_section_status")
  @@index([response_id])
  @@map("survey_section")
}

model SurveyQuestion {
  question_id   Int                           @id @default(autoincrement())
  section_id    Int
  question_key  String                        @db.VarChar(100)
  question_text String
  question_type survey_question_question_type
  options       String?
  required      Boolean                       @default(false)
  order_index   Int                           @default(0)
  depends_on    String?                       @db.VarChar(100)
  depends_value String?                       @db.VarChar(100)
  created_at    DateTime                      @default(now())
  answers       SurveyAnswer[]
  section       SurveySection                 @relation(fields: [section_id], references: [section_id])

  @@index([question_key])
  @@index([section_id])
  @@index([question_type])
  @@map("survey_question")
}

model SurveyAnswer {
  answer_id      Int            @id @default(autoincrement())
  question_id    Int
  response_id    Int
  answer_value   String?        @db.VarChar(255)
  answer_options String?
  answer_text    String?
  answer_number  Decimal?
  answer_rating  Int?
  created_at     DateTime       @default(now())
  updated_at     DateTime?      @updatedAt
  question       SurveyQuestion @relation(fields: [question_id], references: [question_id])
  response       SurveyResponse @relation(fields: [response_id], references: [response_id])

  @@unique([question_id, response_id])
  @@index([response_id])
  @@index([question_id])
  @@map("survey_answer")
}

model SurveyAttachment {
  attachment_id Int            @id @default(autoincrement())
  response_id   Int
  file_name     String         @db.VarChar(255)
  file_path     String         @db.VarChar(500)
  file_type     String?        @db.VarChar(50)
  file_size     Int?
  description   String?
  uploaded_at   DateTime       @default(now())
  response      SurveyResponse @relation(fields: [response_id], references: [response_id])

  @@index([response_id])
  @@index([file_type])
  @@map("survey_attachment")
}

model SurveyMetadata {
  metadata_id Int            @id @default(autoincrement())
  response_id Int
  key_name    String         @db.VarChar(100)
  key_value   String?
  created_at  DateTime       @default(now())
  response    SurveyResponse @relation(fields: [response_id], references: [response_id])

  @@unique([response_id, key_name])
  @@index([response_id])
  @@index([key_name])
  @@map("survey_metadata")
}

model SurveyValidation {
  validation_id      Int                                 @id @default(autoincrement())
  response_id        Int
  validation_type    survey_validation_validation_type
  validation_status  survey_validation_validation_status
  validation_message String?
  validation_data    String?
  created_at         DateTime                            @default(now())
  response           SurveyResponse                      @relation(fields: [response_id], references: [response_id])

  @@index([response_id])
  @@index([validation_type, validation_status])
  @@map("survey_validation")
}

model SurveyCycle {
  cycle_id               Int                      @id @default(autoincrement())
  year                   Int
  start_date             DateTime?
  end_date               DateTime?
  created_at             DateTime                 @default(now())
  updated_at             DateTime?                @updatedAt
  name                   String?                  @db.VarChar(191)
  is_active              Boolean?                 @default(false)
  assignments            Assignment[]
  cpaps                  CPAP[]
  cycle_awards           CycleAward[]
  fieldwork_exceptions   fieldwork_exceptions[]
  questionnaire_counter  questionnaire_counter[]
  questionnaires         Questionnaire[]
  spots                  Spot[]
  supervisor_assignments supervisor_assignments[]
  survey_responses       SurveyResponse[]
  survey_targets         SurveyTarget[]

  @@index([is_active], map: "idx_survey_cycle_is_active")
  @@map("survey_cycle")
}

model SurveyTarget {
  target_id       Int          @id @default(autoincrement())
  barangay_id     Int
  target          Int
  achieved        Int?         @default(0)
  percentage      Int?         @default(0)
  created_at      DateTime     @default(now())
  updated_at      DateTime?    @updatedAt
  survey_cycle_id Int?
  survey_cycle    SurveyCycle? @relation(fields: [survey_cycle_id], references: [cycle_id], onUpdate: NoAction, map: "fk_survey_target_cycle")
  barangay        Barangay     @relation(fields: [barangay_id], references: [barangay_id])

  @@index([barangay_id])
  @@index([survey_cycle_id], map: "idx_survey_target_cycle_id")
  @@map("survey_target")
}

model CycleAward {
  id           Int         @id @default(autoincrement())
  barangay_id  Int
  cycle_id     Int
  is_awardee   Boolean     @default(false)
  awarded_date DateTime?   @db.Timestamp(6)
  notes        String?
  created_at   DateTime?   @default(now()) @db.Timestamp(6)
  updated_at   DateTime?   @default(now()) @updatedAt @db.Timestamp(6)
  created_by   Int?
  barangay     Barangay    @relation(fields: [barangay_id], references: [barangay_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_cycle_awards_barangay")
  survey_cycle SurveyCycle @relation(fields: [cycle_id], references: [cycle_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_cycle_awards_cycle")
  creator      User?       @relation(fields: [created_by], references: [id], onUpdate: NoAction, map: "fk_cycle_awards_user")

  @@unique([barangay_id, cycle_id], map: "uk_cycle_awards_barangay_cycle")
  @@index([barangay_id], map: "idx_cycle_awards_barangay")
  @@index([created_at], map: "idx_cycle_awards_created_at")
  @@index([cycle_id], map: "idx_cycle_awards_cycle")
  @@index([is_awardee], map: "idx_cycle_awards_status")
  @@map("cycle_awards")
}

model Spot {
  spot_id          Int              @id @default(autoincrement())
  cycle_id         Int
  barangay_id      Int
  spot_name        String           @db.VarChar(100)
  starting_point   Json
  random_start     Int
  assigned_fi_id   Int?
  status           SpotStatus       @default(Pending)
  created_at       DateTime         @default(now())
  updated_at       DateTime?        @updatedAt
  questionnaires   Questionnaire[]
  assigned_fi      User?            @relation(fields: [assigned_fi_id], references: [id])
  barangay         Barangay         @relation(fields: [barangay_id], references: [barangay_id], onDelete: Cascade)
  cycle            SurveyCycle      @relation(fields: [cycle_id], references: [cycle_id], onDelete: Cascade)
  survey_responses SurveyResponse[]

  @@index([cycle_id])
  @@index([barangay_id])
  @@index([assigned_fi_id])
  @@index([status])
  @@map("spots")
}

model Questionnaire {
  questionnaire_id        String              @id @db.VarChar(50)
  spot_id                 Int
  cycle_id                Int
  sequence_number         Int
  status                  QuestionnaireStatus @default(Pending)
  visit_count             Int                 @default(0)
  created_at              DateTime            @default(now())
  updated_at              DateTime?           @updatedAt
  assigned_interviewer_id Int?
  user                    User?               @relation(fields: [assigned_interviewer_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  cycle                   SurveyCycle         @relation(fields: [cycle_id], references: [cycle_id], onDelete: Cascade)
  spot                    Spot                @relation(fields: [spot_id], references: [spot_id], onDelete: Cascade)
  survey_response         SurveyResponse?
  visits                  Visit[]

  @@index([spot_id])
  @@index([cycle_id])
  @@index([status])
  @@index([assigned_interviewer_id], map: "idx_questionnaires_assigned_interviewer")
  @@index([spot_id, assigned_interviewer_id], map: "idx_questionnaires_spot_assignment")
  @@map("questionnaires")
}

model Visit {
  visit_id         Int           @id @default(autoincrement())
  questionnaire_id String        @db.VarChar(50)
  visit_number     Int
  visit_timestamp  DateTime      @default(now())
  outcome          VisitOutcome
  notes            String?
  location_lat     Decimal?      @db.Decimal(10, 8)
  location_lng     Decimal?      @db.Decimal(11, 8)
  created_at       DateTime      @default(now())
  questionnaire    Questionnaire @relation(fields: [questionnaire_id], references: [questionnaire_id], onDelete: Cascade)

  @@index([questionnaire_id])
  @@index([visit_timestamp])
  @@map("visits")
}

model CPAP {
  id             Int                @id @default(autoincrement())
  barangay_id    Int
  cycle_id       Int
  status         CPAPStatus         @default(Draft)
  created_at     DateTime           @default(now())
  updated_at     DateTime           @updatedAt
  submitted_at   DateTime?
  approved_at    DateTime?
  admin_comments String?
  comments       CPAPComment[]
  items          CPAPItem[]
  notifications  CPAPNotification[]
  barangay       Barangay           @relation(fields: [barangay_id], references: [barangay_id], onDelete: Cascade)
  cycle          SurveyCycle        @relation(fields: [cycle_id], references: [cycle_id], onDelete: Cascade)

  @@unique([barangay_id, cycle_id])
  @@index([status])
  @@index([barangay_id])
  @@index([cycle_id])
  @@map("cpaps")
}

model CPAPItem {
  id                        Int      @id @default(autoincrement())
  cpap_id                   Int
  priority_area             String   @db.VarChar(255)
  target_output             String
  success_indicator         String
  responsible_person        String   @db.VarChar(255)
  timeline_start            DateTime @db.Date
  timeline_end              DateTime @db.Date
  actual_output             String?
  accomplishment_status     String?  @db.VarChar(50)
  remarks                   String?
  created_at                DateTime @default(now())
  updated_at                DateTime @updatedAt
  observation               String?
  plan_of_action            String?
  activity                  String?
  financial_requirements    String?  @db.VarChar(255)
  committed_to_be_committed String?
  actual_date               String?
  progress                  String?  @db.VarChar(50)
  cpap                      CPAP     @relation(fields: [cpap_id], references: [id], onDelete: Cascade)

  @@index([cpap_id])
  @@map("cpap_items")
}

model CPAPComment {
  id           Int      @id @default(autoincrement())
  cpap_id      Int
  user_id      Int
  comment_text String
  created_at   DateTime @default(now()) @db.Timestamptz(6)
  updated_at   DateTime @default(now()) @updatedAt @db.Timestamptz(6)
  cpap         CPAP     @relation(fields: [cpap_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user         User     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([cpap_id], map: "idx_cpap_comments_cpap_id")
  @@index([created_at(sort: Desc)], map: "idx_cpap_comments_created_at")
  @@index([user_id], map: "idx_cpap_comments_user_id")
  @@map("cpap_comments")
}

model CPAPNotification {
  id                Int      @id @default(autoincrement())
  user_id           Int
  cpap_id           Int
  notification_type String   @db.VarChar(50)
  message           String
  is_read           Boolean  @default(false)
  created_at        DateTime @default(now()) @db.Timestamptz(6)
  created_by        Int?
  cpap              CPAP     @relation(fields: [cpap_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  creator           User?    @relation("CreatedNotifications", fields: [created_by], references: [id], onUpdate: NoAction)
  user              User     @relation("UserNotifications", fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([cpap_id], map: "idx_cpap_notifications_cpap_id")
  @@index([created_at(sort: Desc)], map: "idx_cpap_notifications_created_at")
  @@index([is_read], map: "idx_cpap_notifications_is_read")
  @@index([user_id], map: "idx_cpap_notifications_user_id")
  @@map("cpap_notifications")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model action_grid_classification {
  classification_id     Int       @id @default(autoincrement())
  barangay_id           Int
  section_name          String?
  satisfaction_score    Decimal   @db.Decimal(5, 2)
  need_for_action_score Decimal?  @db.Decimal(5, 2)
  quadrant              String
  recommendations       String?
  created_at            DateTime  @default(now())
  service_name          String?   @db.VarChar(50)
  confidence            Decimal?  @default(0.85) @db.Decimal
  need_action_score     Decimal?  @db.Decimal
  updated_at            DateTime? @default(now()) @db.Timestamp(6)
  barangay              Barangay  @relation(fields: [barangay_id], references: [barangay_id])

  @@index([barangay_id, section_name])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model ai_insight {
  insight_id        Int                 @id @default(autoincrement())
  barangay_id       Int
  insight_type      String
  title             String?             @db.VarChar(200)
  content           String?
  key_findings      String?
  recommendations   String?
  confidence_score  Decimal?            @db.Decimal(5, 4)
  ml_prediction_id  Int?
  created_at        DateTime            @default(now())
  updated_at        DateTime?
  confidence        Decimal?            @db.Decimal(5, 4)
  insight_text      String?
  source            String?             @default("ML_ANALYSIS") @db.VarChar(50)
  barangay          Barangay            @relation(fields: [barangay_id], references: [barangay_id])
  ml_prediction     ml_prediction?      @relation(fields: [ml_prediction_id], references: [prediction_id])
  ai_recommendation ai_recommendation[]

  @@index([barangay_id, insight_type])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model ai_recommendation {
  recommendation_id       Int        @id @default(autoincrement())
  insight_id              Int
  barangay_id             Int
  recommendation_type     String
  priority_level          String?
  title                   String?    @db.VarChar(200)
  description             String?
  expected_impact         String?    @db.VarChar(500)
  resource_requirements   String?
  implementation_timeline String?    @db.VarChar(100)
  success_metrics         String?
  created_at              DateTime   @default(now())
  recommendation_text     String?
  priority                String?    @default("MEDIUM") @db.VarChar(20)
  recommendation_type_alt String?    @db.VarChar(50)
  source                  String?    @default("ML_ANALYSIS") @db.VarChar(50)
  related_insight         String?
  updated_at              DateTime?  @default(now()) @db.Timestamp(6)
  barangay                Barangay   @relation(fields: [barangay_id], references: [barangay_id])
  ai_insight              ai_insight @relation(fields: [insight_id], references: [insight_id])

  @@index([barangay_id, priority_level])
}

model barangay_history {
  history_id  Int       @id @default(autoincrement())
  barangay_id Int
  year        String    @db.VarChar(4)
  status      String    @db.VarChar(50)
  score       String?   @db.VarChar(20)
  notes       String?
  created_at  DateTime  @default(now())
  updated_at  DateTime?
  barangay    Barangay  @relation(fields: [barangay_id], references: [barangay_id])

  @@index([barangay_id])
  @@index([status])
  @@index([year])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
